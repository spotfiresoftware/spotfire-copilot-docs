# Tavily MCP server — sample environment
# Copy to .env and fill in real values. See the Deployment Guide in this folder.

MCP_IMAGE_REF=copilotoci.azurecr.io/spotfirecopilot/mcp-tavily:<image-tag>
HOST=0.0.0.0
PORT=8058
TRANSPORT=streamable-http

# --- Tavily API ---
TAVILY_API_KEY=<tavily-api-key>
TAVILY_READINESS_MODE=config_only

# MCP authentication settings
MCP_AUTH_ENABLED=true
MCP_AUTH_ISSUER_URL=https://auth.example.com
MCP_AUTH_RESOURCE_SERVER_URL=https://mcp.example.com
# Comma-separated required scopes (for JWT/JWKS mode)
MCP_AUTH_REQUIRED_SCOPES=
# Optional JWKS URL. If set, JWT/JWKS validation is used.
MCP_AUTH_JWKS_URL=
# Optional expected JWT audience (aud)
MCP_AUTH_AUDIENCE=
# Comma-separated static bearer tokens.
# If MCP_AUTH_JWKS_URL is empty, static MCP_AUTH_TOKENS validation is used.
# CHANGE this to your own secret token before deploying.
MCP_AUTH_TOKENS=<change-me>
