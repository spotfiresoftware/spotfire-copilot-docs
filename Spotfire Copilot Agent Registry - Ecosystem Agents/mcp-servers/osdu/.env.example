# OSDU MCP server — sample environment
# Copy to .env and fill in real values. See the Deployment Guide in this folder.
# Guide default PORT is 8060; set to 8063 here so it can co-host with Databricks (8061) and DV (8065).
# For a standalone host you may revert to PORT=8060.

MCP_IMAGE_REF=copilotoci.azurecr.io/spotfirecopilot/mcp-osdu:<image-tag>
HOST=0.0.0.0
PORT=8063
TRANSPORT=streamable-http

# --- OSDU platform (OAuth client-credentials) ---
OSDU_BASE_URL=https://<osdu-base>
OSDU_PARTITION=<partition>
OSDU_TOKEN_URL=https://<osdu-token-endpoint>
OSDU_CLIENT_ID=<client-id>
OSDU_CLIENT_SECRET=<client-secret>

# --- Optional OSDU tuning ---
# OSDU_VERIFY_TLS=false
# OSDU_TIMEOUT=30.0
# OSDU_BUILD_TAG=2026.05.29
# OSDU_SCHEMA_CACHE_TTL_SECONDS=300

# MCP authentication settings
MCP_AUTH_ENABLED=true
MCP_AUTH_ISSUER_URL=https://auth.example.com
MCP_AUTH_RESOURCE_SERVER_URL=https://mcp.example.com
# Comma-separated required scopes (for JWT/JWKS mode)
MCP_AUTH_REQUIRED_SCOPES=
# Optional JWKS URL. If set, JWT/JWKS validation is used.
MCP_AUTH_JWKS_URL=
# Optional expected JWT audience (aud)
MCP_AUTH_AUDIENCE=
# Comma-separated static bearer tokens.
# If MCP_AUTH_JWKS_URL is empty, static MCP_AUTH_TOKENS validation is used.
# CHANGE this to your own secret token before deploying.
MCP_AUTH_TOKENS=<change-me>
