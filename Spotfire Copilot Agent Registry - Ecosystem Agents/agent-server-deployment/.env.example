# DeepAgents OSS server — sample environment
# Copy to .env and fill in real values. See the OSS Deployment Guide in this folder.

AGENT_IMAGE_REF=copilotoci.azurecr.io/spotfirecopilot/copilot-deepagents-server-oss:<image-tag>

# --- Core runtime ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
PUBLIC_BASE_URL=http://localhost:8000

# --- State stores (provided by docker-compose.yml) ---
POSTGRES_URL=postgresql://postgres:postgres@deepagents-oss-postgres:5432/deepagents_checkpoints
REDIS_URL=redis://deepagents-oss-redis:6379/0

# --- Inbound A2A auth ---
A2A_AUTH_MODE=bearer
A2A_AUTH_PUBLIC_CARD=true
A2A_BEARER_TOKENS=change-me-token-1,change-me-token-2

# --- LLM provider/model (set the key matching DEEPAGENTS_MODEL) ---
# Public OpenAI (default):
DEEPAGENTS_MODEL=openai:gpt-5.1
OPENAI_API_KEY=replace-me
# ANTHROPIC_API_KEY=replace-me   # for anthropic:* models
# GOOGLE_API_KEY=replace-me      # for google:* models
#
# Azure OpenAI: set DEEPAGENTS_MODEL to azure_openai:<deployment-name> — the value
# after the colon is the Azure DEPLOYMENT name, NOT the model name. Provide the
# three AZURE_* vars below INSTEAD OF OPENAI_API_KEY. (OPENAI_API_VERSION may also
# be given as AZURE_OPENAI_API_VERSION.) No docker-compose.yml change is needed —
# these are read from this .env via env_file.
# DEEPAGENTS_MODEL=azure_openai:my-gpt5-deployment
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_API_KEY=replace-me
# OPENAI_API_VERSION=2024-10-21
# DEEPAGENTS_MODEL_PROVIDER is optional and usually unnecessary — the azure_openai:
# prefix above already selects Azure. Only set it to "azure" to force Azure when
# DEEPAGENTS_MODEL has NO provider prefix (a bare deployment name).
# DEEPAGENTS_MODEL_PROVIDER=azure

# --- Agent selection (allow-list; enable only what you deploy) ---
# Full set: osdu_agent,databricks_agent,databricks_genie_agent,snowflake_agent,
#           dv_agent,sf_lib_md_agent,sf_lic_agent,tavily_agent,milvus_agent,ddr_agent
AGENTS_ENABLED=databricks_agent

# --- Per-agent MCP wiring -----------------------------------------------------
# Each agent's tools load from its MCP server URL. When the MCP servers run as
# SEPARATE compose stacks on the SAME host, reach them from inside this container
# via host.docker.internal:<port>/mcp. Ports below match each MCP server's .env.example.
# (Linux: uncomment extra_hosts in docker-compose.yml so the name resolves.)
# Uncomment the lines for each agent you enable in AGENTS_ENABLED.
#
# NOTE: the Databricks, OSDU, and DV guides default to PORT=8060. The bundled
# .env files assign unique co-hosting ports (Databricks 8061, OSDU 8063, DV 8065)
# so they can run together on one host; the URLs below already match those ports.

# Spotfire Library (sf_lib_md_agent) — port 8062
# SFLIB_MCP_SERVER_URL=http://host.docker.internal:8062/mcp
# SFLIB_MCP_SERVER_TRANSPORT=streamable-http
# SFLIB_MCP_BEARER_TOKEN=replace-me   # only if that MCP has inbound auth enabled

# Databricks (databricks_agent) — port 8061
DATABRICKS_MCP_SERVER_URL=http://host.docker.internal:8061/mcp
DATABRICKS_MCP_SERVER_TRANSPORT=streamable-http
DATABRICKS_MCP_BEARER_TOKEN=replace-me

# OSDU (osdu_agent) — port 8063
# OSDU_MCP_SERVER_URL=http://host.docker.internal:8063/mcp
# OSDU_MCP_SERVER_TRANSPORT=streamable-http
# OSDU_MCP_BEARER_TOKEN=replace-me

# Data Virtualization (dv_agent) — port 8065
# DV_MCP_SERVER_URL=http://host.docker.internal:8065/mcp
# DV_MCP_SERVER_TRANSPORT=streamable-http
# DV_MCP_BEARER_TOKEN=replace-me

# Energy DDR Neo4j (ddr_agent) — port 8060
# DDR_MCP_SERVER_URL=http://host.docker.internal:8060/mcp
# DDR_MCP_SERVER_TRANSPORT=streamable-http
# DDR_MCP_BEARER_TOKEN=replace-me

# Spotfire License (sf_lic_agent) — port 8064
# SFLIC_MCP_SERVER_URL=http://host.docker.internal:8064/mcp
# SFLIC_MCP_SERVER_TRANSPORT=streamable-http
# SFLIC_MCP_BEARER_TOKEN=replace-me

# Tavily (tavily_agent) — port 8058
# TAVILY_MCP_SERVER_URL=http://host.docker.internal:8058/mcp
# TAVILY_MCP_SERVER_TRANSPORT=streamable-http
# TAVILY_MCP_BEARER_TOKEN=replace-me

# --- Optional outbound MCP auth via Keycloak client_credentials (aud=mcp) ------
# When all three are set, the server mints fresh per-request tokens and the
# static *_MCP_BEARER_TOKEN values above are ignored. Leave blank to use static tokens.
# MCP_CLIENT_ID=mcp-clients
# MCP_CLIENT_SECRET=replace-me
# KEYCLOAK_TOKEN_URL=https://keycloak.example.com/realms/master/protocol/openid-connect/token
